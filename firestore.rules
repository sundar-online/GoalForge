rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Lock down user-scoped directories securely.
    // Users can only read and write their own documents & nested sub-collections.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
